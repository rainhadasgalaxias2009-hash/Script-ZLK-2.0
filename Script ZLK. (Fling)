local tinyDragging = false
local tinyDragStart = Vector2.new()
local tinyStartPos = UDim2.new()

tinyFrame.InputBegan:Connect(function(input)
    if not tinyDraggableEnabled then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        tinyDragging = true
        tinyDragStart = input.Position
        tinyStartPos = tinyFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                tinyDragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if tinyDragging and tinyDraggableEnabled and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - tinyDragStart
        tinyFrame.Position = UDim2.new(
            tinyStartPos.X.Scale,
            tinyStartPos.X.Offset + delta.X,
            tinyStartPos.Y.Scale,
            tinyStartPos.Y.Offset + delta.Y
        )
    end
end)

