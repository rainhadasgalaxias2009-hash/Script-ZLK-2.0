local rememberedTargets = {} -- [UserId] = true
local function createPlayerCard(targetPlayer)
    if targetPlayer == player then return end
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1,-10,0,50)
    card.BackgroundColor3 = darkColor
    card.Parent = listArea
    card.ClipsDescendants = true
    Instance.new("UICorner", card).CornerRadius = UDim.new(0,6)
    local stroke = addRGBBorder(card,1)

    local avatar = Instance.new("ImageLabel")
    avatar.Size = UDim2.new(0,40,0,40)
    avatar.Position = UDim2.fromOffset(5,5)
    avatar.BackgroundTransparency = 1
    avatar.Parent = card

    task.spawn(function()
        local success, thumb = pcall(function()
            return Players:GetUserThumbnailAsync(targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        end)
        if success then avatar.Image = thumb end
    end)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1,-60,1,0)
    nameLabel.Position = UDim2.fromOffset(50,0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = targetPlayer.DisplayName.." ("..targetPlayer.Name..")"
    nameLabel.Font = Enum.Font.Bodoni
    nameLabel.TextSize = 20
    nameLabel.TextColor3 = Color3.fromRGB(255,255,255)
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextYAlignment = Enum.TextYAlignment.Center
    nameLabel.Parent = card
    addGrayTextStroke(nameLabel,2)

    local selectBox = Instance.new("TextButton")
    selectBox.Size = UDim2.new(0,30,0,30)
    selectBox.Position = UDim2.new(1,-35,0.5,-15)
    selectBox.BackgroundColor3 = Color3.fromRGB(100,100,100)
    selectBox.BackgroundTransparency = 0.5
    selectBox.Parent = card
    Instance.new("UICorner", selectBox).CornerRadius = UDim.new(0,4)
    selectBox.Text = ""

    local xLabel = Instance.new("TextLabel")
    xLabel.Size = UDim2.new(1,0,1,0)
    xLabel.Position = UDim2.fromOffset(0,0)
    xLabel.BackgroundTransparency = 1
    xLabel.Text = "X"
    xLabel.Font = Enum.Font.Bodoni
    xLabel.TextColor3 = RGBColor(hue)
    xLabel.TextSize = 24
    xLabel.TextXAlignment = Enum.TextXAlignment.Center
    xLabel.TextYAlignment = Enum.TextYAlignment.Center
    xLabel.Visible = false
    xLabel.Parent = selectBox

    selectBox.MouseButton1Click:Connect(function()
    xLabel.Visible = not xLabel.Visible
    stroke.Thickness = xLabel.Visible and 3 or 1

    -- salva ou remove da memória
    if xLabel.Visible then
        rememberedTargets[targetPlayer.UserId] = true
    else
        rememberedTargets[targetPlayer.UserId] = nil
    end
end)

    playerCards[targetPlayer] = {Card = card, Stroke = stroke, Label = nameLabel, X = xLabel, Box = selectBox}
-- restaurar seleção se já estava salvo
if rememberedTargets[targetPlayer.UserId] then
    xLabel.Visible = true
    stroke.Thickness = 3
end
end

